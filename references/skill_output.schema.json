{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RNAseqAnalysisOutput",
  "type": "object",
  "required": ["outdir", "final_variant", "files"],
  "properties": {
    "outdir": { "type": "string" },
    "final_variant": { "type": "string" },
    "group_count": { "type": "integer" },
    "comparisons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stability_summary": {
      "type": "object",
      "properties": {
        "variant_count": { "type": "integer" },
        "selected_reason": { "type": "string" }
      },
      "additionalProperties": true
    },
    "files": {
      "type": "object",
      "properties": {
        "report_md": { "type": "string" },
        "config_json": { "type": "string" },
        "manifest_json": { "type": "string" },
        "variant_summary_csv": { "type": "string" },
        "log_txt": { "type": "string" },
        "pca_pdf": { "type": "string" },
        "pca_data_csv": { "type": "string" },
        "vsd_csv": { "type": "string" },
        "deg_summary_csv": { "type": "string" },
        "selected_deseq2_dir": { "type": "string" },
        "selected_figures_dir": { "type": "string" },
        "selected_tables_dir": { "type": "string" },
        "selected_comparison_dir": { "type": "string" },
        "selected_deg_dir": { "type": "string" },
        "selected_enrichment_dir": { "type": "string" },
        "selected_tcseq_dir": { "type": "string" }
      },
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
