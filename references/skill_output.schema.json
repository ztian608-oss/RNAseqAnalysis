{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DESeq2GenericOutput",
  "type": "object",
  "required": ["outdir", "files"],
  "properties": {
    "outdir": { "type": "string" },
    "comparisons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Comparison names, e.g. treat_vs_control"
    },
    "significant_gene_count": { "type": "integer", "minimum": 0 },
    "files": {
      "type": "object",
      "properties": {
        "vsd_csv": { "type": "string" },
        "pca_pdf": { "type": "string" },
        "pca_data_csv": { "type": "string" },
        "de_result_list_rds": { "type": "string" },
        "significant_genes_txt": { "type": "string" },
        "significant_heatmap_pdf": { "type": "string" },
        "timecourse_cluster_heatmap_pdf": { "type": "string" },
        "timecourse_cluster_result_csv": { "type": "string" },
        "timecourse_cluster_patterns_pdf": { "type": "string" }
      },
      "additionalProperties": {
        "type": "string",
        "description": "Additional output file path"
      }
    }
  },
  "additionalProperties": false
}
